# Set when using external PostgreSQL, for example:
# POSTGRES_DSN=postgresql://user:password@db-host:5432/dbname
# Required for API startup.
POSTGRES_DSN=postgresql://user:password@db-host:5432/dbname
# Optional fallback key (used when POSTGRES_DSN is empty)
DB_URI=

# Docker Compose optional variable
APP_PORT=8299

# FoxuAI API base URL
FOXUAI_BASE_URL=https://foxuai.com
# FoxuAI Authorization header (preferred, full value like "Bearer xxx")
FOXUAI_AUTHORIZATION=
# Alternative: raw token/JWT (code will auto-prefix "Bearer ")
FOXUAI_BEARER_TOKEN=

# OpenViking server connection (used by this backend, recommended remote HTTP server)
OPENVIKING_URL=http://127.0.0.1:1933
OPENVIKING_API_KEY=

# OpenViking embedding model (required for vectorization/search indexing)
OPENVIKING_EMBED_PROVIDER=openai
OPENVIKING_EMBED_MODEL=doubao-embedding-large-text-240915
OPENVIKING_EMBED_API_KEY=
OPENVIKING_EMBED_API_BASE=https://aihubmix.com/v1
OPENVIKING_EMBED_DIMENSION=4096

# OpenViking chat/LLM model (optional; only for advanced generation/reasoning flows)
OPENVIKING_LLM_PROVIDER=openai
OPENVIKING_LLM_MODEL=grok-4-fast-non-reasoning
OPENVIKING_LLM_API_KEY=
OPENVIKING_LLM_API_BASE=https://aihubmix.com/v1

# MinerU OCR
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm

PYTHONPATH=src
